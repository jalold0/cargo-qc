# ============================================================
# Cargo-QC Frontend — Environment Variables Example
# ============================================================
# Loyihani ishga tushirishdan oldin shu faylni `.env.local` ga
# nusxalang va o'z qiymatlaringiz bilan to'ldiring:
#
#   cp .env.example .env.local
# ============================================================

# Backend API (kelajakda)
# Local development: http://localhost:5000/api
# Production: https://api.your-domain.com
VITE_API_URL=http://localhost:5000/api

# ============================================================
# Supabase (REST + Realtime)
# ============================================================
# Supabase loyihangizdan oling:
#   Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Anon (public) key — RLS bilan himoyalanadi
#   Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=

# ============================================================
# Sales Data Backend (Optional)
# ============================================================
# Oylik sotuv ma'lumotlari uchun endpoint
# Format: GET ?year=2026 -> { "0": { totalTracks, totalKg }, ... }
VITE_SALES_API_URL=

# ============================================================
# CRM Scraper (Module 102)
# ============================================================
# iPOST CRM ichki tarmoq IP yoki URL
# CORS muammosini oldini olish uchun backend proxy ishlatilsin
VITE_CRM_BASE_URL=

# ============================================================
# Eslatma:
# - Vite faqat `VITE_` prefixli o'zgaruvchilarni client'ga uzatadi
# - .env.local fayli `.gitignore`'da bo'lishi shart
# - Production secret'larni client kodga qo'shmang (RLS ishlating)
# ============================================================
